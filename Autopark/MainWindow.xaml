<Window x:Class="Autopark.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Autopark"
        mc:Ignorable="d"
        Title="Автопарк" Height="450" Width="800"
        Loaded="Window_Loaded">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="Менеджер: " VerticalAlignment="Center"/>
            <TextBlock x:Name="txtUserInfo" VerticalAlignment="Center" FontWeight="Bold"/>
            <Button Content="Выход" Click="BtnLogout_Click" Margin="20,0,0,0" Width="60"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Button x:Name="btnCreateRequest" Content="Оформить заявку на ТО" Click="BtnCreateRequest_Click" 
                    HorizontalAlignment="Left" Margin="0,0,0,10" Padding="10,5"/>

            <DataGrid x:Name="dgCars" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding id}"/>
                    <DataGridTextColumn Header="Марка" Binding="{Binding brand}"/>
                    <DataGridTextColumn Header="Модель" Binding="{Binding model}"/>
                    <DataGridTextColumn Header="Год" Binding="{Binding year}"/>
                    <DataGridTextColumn Header="Госномер" Binding="{Binding license_plate}"/>
                    <DataGridTextColumn Header="Пробег" Binding="{Binding mileage}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>