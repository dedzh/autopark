<Window x:Class="Autopark.CreateRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Autopark"
        mc:Ignorable="d"
        Title="Новая заявка на ТО" Height="250" Width="400" WindowStartupLocation="CenterOwner">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Автомобиль:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBlock x:Name="txtCarInfo" Grid.Row="1" Margin="0,0,0,10"/>

        <TextBlock Text="Описание работ:" Grid.Row="2" Margin="0,0,0,5"/>
        <TextBox x:Name="txtDescription" Grid.Row="3" TextWrapping="Wrap" AcceptsReturn="True" 
                 Height="80" VerticalScrollBarVisibility="Auto"/>

        <StackPanel Orientation="Horizontal" Grid.Row="4" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Сохранить" Click="BtnSave_Click" Width="75" Margin="2"/>
            <Button Content="Отмена" Click="BtnCancel_Click" Width="75" Margin="2"/>
        </StackPanel>
    </Grid>
</Window>
